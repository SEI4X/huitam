rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isChatParticipant(chatId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantUIDs;
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(uid)
        && request.resource.data.uid == resource.data.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'messagesPracticed',
          'cardsSaved',
          'correctionsUsed',
          'streakDays'
        ]);

      match /private/{document} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid) && document == 'settings';
      }

      match /deviceTokens/{token} {
        allow read: if false;
        allow create, update: if isOwner(uid)
          && request.resource.data.token == token
          && request.resource.data.platform == 'ios';
        allow delete: if isOwner(uid);
      }

      match /studyCards/{cardId} {
        allow read, write: if isOwner(uid);
      }
    }

    match /usernames/{nickname} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.uid == request.auth.uid;
    }

    match /chats/{chatId} {
      allow read: if isChatParticipant(chatId);
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participantUIDs
        && request.resource.data.participantUIDs.size() == 2;
      allow update: if isChatParticipant(chatId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['participantUIDs', 'roles']);

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId)
          && request.resource.data.senderUID == request.auth.uid
          && request.resource.data.originalText is string
          && request.resource.data.translatedText is string;
        allow update: if false;
        allow delete: if false;
      }
    }

    match /invites/{inviteId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.inviterUID == request.auth.uid
        && request.resource.data.status == 'open';
      allow update: if signedIn()
        && resource.data.status == 'open'
        && request.resource.data.guestUID == request.auth.uid
        && request.resource.data.status == 'accepted'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'guestUID',
          'chatID',
          'acceptedAt'
        ]);
    }
  }
}
