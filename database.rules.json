{
  "rules": {
    ".read": false,
    ".write": false,
    "presence": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $uid",
        ".validate": "newData.hasChildren(['state', 'lastChanged']) && newData.child('state').isString() && (newData.child('state').val() == 'online' || newData.child('state').val() == 'offline') && newData.child('lastChanged').isNumber()"
      }
    }
  }
}
